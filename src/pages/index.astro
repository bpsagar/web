---
import { getCollection } from 'astro:content';
import RolePill from '../components/RolePill.astro';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@300..800&family=Instrument+Serif&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen">
		<div class="max-w-[500px] mx-auto px-6">
			<nav class="sticky top-0 z-50 flex items-center h-20 font-host font-medium text-lg bg-transparent">
				<span>sagar.im</span>
			</nav>
			<section class="relative min-h-screen flex flex-col justify-center py-20 overflow-hidden">
				<!-- Heading -->
				<h1 class="font-instrument text-zinc-900 text-[8vw] md:text-[3vw] leading-[1.6] mb-10 tracking-tight">
					I'm Sagar, a <span class="inline-block whitespace-nowrap"><RolePill role="Software Engineer" emoji="💻" />,</span> <span class="inline-block whitespace-nowrap"><RolePill role="Maker" emoji="🛠️" /> and</span> <span class="inline-block whitespace-nowrap"><RolePill role="Portrait Artist" emoji="✍️" />,</span> based in Singapore.
				</h1>
			</section>

			<main class="mt-[15vw] mb-20">
				<section class="w-full">
					<div class="mb-16">
						<h2 class="font-host font-medium text-[4vw] md:text-[1.2vw] uppercase tracking-widest text-primary mb-4">Apps</h2>
						<p class="font-host font-light text-[6vw] md:text-[2.5vw] text-zinc-500">
							These are my personal projects,<br class="md:hidden" /> both past and ongoing:
						</p>
					</div>

					<div class="flex overflow-x-auto no-scrollbar gap-8 snap-x snap-mandatory -mx-6 px-6">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="flex-none w-[80vw] md:w-[400px] snap-center group border border-zinc-100 hover:border-primary/30 transition-all duration-500 p-10 bg-zinc-50/50 hover:bg-white hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] text-left"
						>
							<div class="mb-4">
								<img src={app.data.logo} alt={app.data.name} class="w-12 h-12 rounded-lg grayscale group-hover:grayscale-0 transition-all duration-500" />
							</div>
							<h3 class="font-host font-bold text-[5vw] md:text-[2vw] mb-2 text-zinc-900 group-hover:text-primary transition-colors duration-300">{app.data.name}</h3>
							<p class="font-host font-light text-[3.5vw] md:text-[1.2vw] text-zinc-500">
								{app.data.description}
							</p>
						</a>
					))}
				</div>
			</section>
			</main>
		</div>
	</body>
</html>
