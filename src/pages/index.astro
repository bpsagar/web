---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen">
		<div class="max-w-[500px] mx-auto px-6">
			<Header />
			<section class="relative pt-2 pb-8 overflow-hidden">
				<!-- Heading -->
				<h1 class="font-plus font-semibold tracking-tight text-zinc-400 text-[8vw] md:text-[3vw]">A <span class="text-zinc-900">software engineer</span>, <span class="text-zinc-900">maker</span> and <span class="text-zinc-900">portrait artist</span>, based in Singapore.</h1>
			</section>

			<main class="mt-4 mb-20">
				<section class="w-full">
					<Header title="a maker" />

					<div class="grid grid-cols-1 gap-2.5">
					{sortedApps.map((app) => (
						<div class="group relative bg-zinc-50/50 border border-zinc-200 rounded-xl p-3 transition-all duration-500 hover:border-zinc-300 hover:bg-zinc-50">
							<div class="flex items-center gap-4">
								<div class="w-10 h-10 flex items-center justify-center">
									<img
										src={app.data.logo}
										alt={app.data.name}
										class="w-8 h-8 object-contain transition-all duration-500"
									/>
								</div>
								<h3 class="font-host font-bold text-xs text-zinc-900 uppercase tracking-[0.2em] transition-colors duration-300">
									{app.data.name}
								</h3>
							</div>

							<div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-500 ease-in-out opacity-0 group-hover:opacity-100">
								<div class="overflow-hidden">
									<p class="font-host text-[11px] text-zinc-500 leading-relaxed mt-4 mb-4">
										{app.data.description}
									</p>
									<a
										href={app.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="inline-flex items-center gap-1.5 text-primary text-[10px] font-bold uppercase tracking-widest hover:gap-2 transition-all duration-300"
									>
										View Project
										<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
									</a>
								</div>
							</div>
						</div>
					))}
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
