---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Header from '../components/Header.astro';
import '../styles/global.css';
import profileImage from '../assets/profile.png';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);

const allPortraits = await getCollection('portraits');
const sortedPortraits = allPortraits.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "profile.png"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen overflow-x-hidden">
		<div class="max-w-[500px] mx-auto px-6">
			<Header showAvatar={true} />
			<section class="relative pt-2 pb-8 overflow-hidden">
				<!-- Profile Picture -->
				<div id="hero-profile-pic" class="mb-6 w-24 h-24 rounded-full overflow-hidden border border-zinc-200">
					<Image
						src={profileImage}
						alt="Sagar Chakravarthy"
						width={96}
						height={96}
						class="w-full h-full object-cover"
						loading="eager"
					/>
				</div>
				<!-- Heading -->
				<h1 class="font-plus font-semibold tracking-tight text-zinc-400 text-[5vw] md:text-[1.5vw]">
					A <span class="text-zinc-900">software engineer</span>, <span class="text-zinc-900">maker</span> and <span class="text-zinc-900">portrait artist</span>, based in Singapore.
					<span class="block mt-4">On a lifelong pursuit of the perfect masala chai, which is a convenient excuse to drink it every day.</span>
					<span class="block mt-4">Otherwise, you’ll find me at the gym or on a tennis court. Only places my brain hits 'quiet mode'.</span>
				</h1>
			</section>

			<main class="mt-4 mb-20">
				<section class="w-full">
					<Header title="a maker" showAvatar={true} />

					<div class="flex flex-col border-t border-zinc-200 overflow-visible">
					{sortedApps.map((app) => (
						<div class="group border-b border-x border-zinc-200 transition-colors duration-300 hover:bg-zinc-50/50">
							<input
								type="checkbox"
								id={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
								class="peer hidden"
							/>
							<div class="relative flex items-start gap-4 py-4 px-4 peer-checked:[&_.logo]:w-12 peer-checked:[&_.logo]:h-12 peer-checked:[&_.desc-grid]:grid-rows-[1fr] peer-checked:[&_.desc-text]:opacity-100 peer-checked:[&_label]:z-0 peer-checked:[&_.desc-inner]:overflow-visible">
								<!-- Label for toggle -->
								<label
									for={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
									class="absolute inset-0 z-30 cursor-pointer"
								></label>

								<!-- Logo -->
								<div class="flex-shrink-0 z-20 transition-all duration-500 logo w-6 h-6">
									<img
										src={app.data.logo}
										alt={app.data.name}
										class="w-full h-full object-contain"
									/>
								</div>

								<!-- Content (Title + Description) -->
								<div class="flex-1 z-20">
									<div class="h-6 flex items-center">
										<h3 class="font-host font-bold text-xs text-zinc-900 uppercase tracking-[0.2em] leading-none">
											{app.data.name}
										</h3>
									</div>
									<div class="grid grid-rows-[0fr] transition-all duration-500 ease-in-out desc-grid">
										<div class="overflow-hidden desc-inner">
											<p
												class="font-plus text-[12px] text-zinc-500 leading-relaxed mt-2 opacity-0 transition-opacity duration-500 desc-text"
												set:html={app.data.description}
											/>
										</div>
									</div>
								</div>

								<!-- Link -->
								<div class="z-40 relative h-6 flex items-center">
									<a
										href={app.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-zinc-300 hover:text-zinc-900 transition-colors duration-300 p-1 block"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<line x1="7" y1="17" x2="17" y2="7"></line>
											<polyline points="7 7 17 7 17 17"></polyline>
										</svg>
									</a>
								</div>
							</div>
						</div>
					))}
					</div>
				</section>

				<section class="w-full mt-12">
					<Header title="a portrait artist" showAvatar={true} />
					<div class="-mr-6 md:-mr-[calc(50vw-226px)]">
						<div class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar gap-6 pb-4 pr-6 md:pr-[calc(50vw-226px)]">
							{sortedPortraits.map((portrait) => (
								<div class="flex-none w-[280px] snap-start">
									<div class="aspect-[3/4] overflow-hidden border border-zinc-200 bg-zinc-50">
										<img
											src={portrait.data.image}
											alt={portrait.data.title}
											class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
										/>
									</div>
									<div class="mt-3 h-6 flex items-center">
										<h3 class="font-host font-bold text-xs text-zinc-900 uppercase tracking-[0.2em] leading-none">
											{portrait.data.title}
										</h3>
									</div>
								</div>
							))}
						</div>
					</div>
				</section>
			</main>
		</div>

		<script>
			// Page Comment Logic
			document.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				const commentTrigger = target.closest('[data-comment]');

				if (commentTrigger) {
					e.preventDefault();
					const commentText = (commentTrigger as HTMLElement).dataset.comment;
					const triggerText = commentTrigger.textContent || '';
					const blockParent = commentTrigger.closest('p, h1, h2, h3, div');
					const container = blockParent?.parentElement;

					if (!blockParent || !container || !commentText) return;

					// Check if comment already exists for this trigger (as a sibling of blockParent)
					const existingComments = container.querySelectorAll('.page-comment');
					let isSameComment = false;
					existingComments.forEach(c => {
						if ((c as HTMLElement).dataset.for === triggerText) {
							isSameComment = true;
						}
						c.remove();
					});

					if (isSameComment) return;

					const commentEl = document.createElement('div');
					commentEl.className = 'page-comment';
					commentEl.dataset.for = triggerText;
					commentEl.innerHTML = `
						<div class="page-comment-header">
							<img src="/profile.png" class="page-comment-avatar" />
							<span class="page-comment-author">Sagar Chakravarthy</span>
						</div>
						<div class="page-comment-body">
							${commentText}
						</div>
						<span class="page-comment-close">✕</span>
					`;

					commentEl.querySelector('.page-comment-close')?.addEventListener('click', (e) => {
						e.stopPropagation();
						commentEl.remove();
					});

					// Insert before the block parent
					container.insertBefore(commentEl, blockParent);
				}
			});

			const heroProfilePic = document.getElementById('hero-profile-pic');
			const headerAvatars = document.querySelectorAll('.header-avatar');

			if (heroProfilePic && headerAvatars.length > 0) {
				const observer = new IntersectionObserver(
					([entry]) => {
						headerAvatars.forEach((avatar) => {
							if (!entry.isIntersecting) {
								// Hero pic is out of view, show header avatars
								avatar.classList.remove('opacity-0', '-translate-x-4', 'w-0');
								avatar.classList.add('opacity-100', 'translate-x-0', 'w-5', 'mr-3');
							} else {
								// Hero pic is in view, hide header avatars
								avatar.classList.add('opacity-0', '-translate-x-4', 'w-0');
								avatar.classList.remove('opacity-100', 'translate-x-0', 'w-5', 'mr-3');
							}
						});
					},
					{ threshold: 0 }
				);

				observer.observe(heroProfilePic);
			}
		</script>
	</body>
</html>
