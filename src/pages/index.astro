---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Header from '../components/Header.astro';
import Comment from '../components/Comment.astro';
import '../styles/global.css';
import profileImage from '../assets/profile.png';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);

const allPortraits = await getCollection('portraits');
const sortedPortraits = allPortraits.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "profile.png"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen overflow-x-hidden">
		<div class="max-w-[500px] mx-auto px-6">
			<Header showAvatar={true} />
			<section class="relative pt-2 pb-8 overflow-hidden">
				<!-- Profile Picture -->
				<div id="hero-profile-pic" class="mb-6 w-24 h-24 rounded-full overflow-hidden border border-zinc-200">
					<Image
						src={profileImage}
						alt="Sagar Chakravarthy"
						width={192}
						height={192}
						class="w-full h-full object-cover"
						loading="eager"
					/>
				</div>
				<!-- Heading -->
				<h1 class="font-plus font-medium tracking-tight text-zinc-400 text-2xl">
					A <span class="text-zinc-900">software engineer</span>, <span class="text-zinc-900">maker</span> and <span class="text-zinc-900">portrait artist</span>, based in Singapore.
					<span class="block mt-4">On a lifelong pursuit of the perfect masala chai, which is a convenient excuse to drink it every day.</span>
					<span class="block mt-4">Otherwise, you’ll find me at the gym or on a tennis court. Only places my brain hits 'quiet mode'.</span>
				</h1>
			</section>

			<main class="mt-4 mb-20">
				<section class="w-full">
					<Header title="a maker" showAvatar={true} />

					<div class="flex flex-col border-t border-zinc-200 overflow-visible maker-list">
					{sortedApps.map((app) => (
						<div
							class="group relative border-b border-x border-zinc-200 transition-all duration-500 app-card overflow-hidden hover:z-20 peer-checked:z-30"
							style={`--app-color: ${app.data.color};`}
						>
							<input
								type="checkbox"
								id={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
								class="peer hidden"
							/>

							<!-- Interactive Border Glow -->
							<div class="absolute inset-0 opacity-0 peer-checked:opacity-100 transition-opacity duration-700 pointer-events-none z-0">
								<div class="absolute inset-[1px] border border-white/20 rounded-[inherit]"></div>
								<div class="absolute inset-0 border border-transparent [border-image:linear-gradient(to_bottom,var(--app-color),transparent)_1] opacity-20"></div>
							</div>

							<!-- Spotlight Gradient -->
							<div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0 spotlight" style="background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), color-mix(in srgb, var(--app-color) 12%, transparent), transparent 40%);"></div>

							<!-- Glassmorphism Background -->
							<div class="absolute inset-0 opacity-0 peer-checked:opacity-100 transition-all duration-700 pointer-events-none z-0 backdrop-blur-2xl" style={`background: linear-gradient(135deg, color-mix(in srgb, ${app.data.color} 8%, transparent), color-mix(in srgb, ${app.data.color} 2%, transparent));`}></div>

							<div class="relative flex items-start gap-4 py-5 px-4 peer-checked:py-8 transition-all duration-500 peer-checked:[&_.logo]:w-14 peer-checked:[&_.logo]:h-14 peer-checked:[&_.desc-grid]:grid-rows-[1fr] peer-checked:[&_.desc-text]:opacity-100 peer-checked:[&_.desc-inner]:overflow-visible z-10">
								<!-- Label for toggle -->
								<label
									for={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
									class="absolute inset-0 z-30 cursor-pointer"
								></label>

								<!-- Logo -->
								<div class="flex-shrink-0 z-10 transition-all duration-500 logo w-6 h-6">
									<Image
										src={app.data.logo}
										alt={app.data.name}
										width={56}
										height={56}
										class="w-full h-full object-contain"
									/>
								</div>

								<!-- Content (Title + Description) -->
								<div class="flex-1 min-w-0">
									<div class="flex flex-col md:flex-row md:items-center gap-1.5 md:gap-3">
										<div class="flex items-center gap-2">
											<h3 class="font-host font-bold text-[14px] uppercase tracking-wider text-zinc-900 truncate">
												{app.data.name}
											</h3>
											<span class="md:hidden text-[10px] font-host text-zinc-400 ml-auto">
												{app.data.year}
											</span>
										</div>
										<div class="flex items-center gap-2">
											<span class="text-[9px] px-2 py-0.5 rounded-full border border-zinc-200 text-zinc-500 font-bold uppercase tracking-[0.1em] bg-white/50 backdrop-blur-sm whitespace-nowrap">
												{app.data.tag}
											</span>
											<span class="hidden md:block text-[10px] font-host text-zinc-400 ml-auto mr-1">
												{app.data.year}
											</span>
										</div>
									</div>
									<div class="grid grid-rows-[0fr] transition-all duration-500 ease-in-out desc-grid">
										<div class="overflow-hidden desc-inner">
											<p
												class="font-plus text-zinc-600 leading-relaxed mt-4 opacity-0 transition-opacity duration-500 desc-text text-[13px]"
												set:html={app.data.description}
											/>
										</div>
									</div>
								</div>

								<!-- Link -->
								<div class="z-40 relative h-6 flex items-center md:mt-0.5">
									<a
										href={app.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-zinc-300 hover:text-zinc-900 transition-all duration-300 p-1 block hover:scale-110 active:scale-95"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<line x1="7" y1="17" x2="17" y2="7"></line>
											<polyline points="7 7 17 7 17 17"></polyline>
										</svg>
									</a>
								</div>
							</div>
						</div>
					))}
					</div>
				</section>

				<section class="w-full mt-12">
					<Header title="a portrait artist" showAvatar={true} />
					<div class="-mr-6 md:-mr-[calc(50vw-226px)]">
						<div class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar pb-4 pr-6 md:pr-[calc(50vw-226px)]">
							{sortedPortraits.map((portrait, index) => (
								<div class="flex-none w-[280px] snap-start">
									<div class={`aspect-[3/4] overflow-hidden border-y border-l border-zinc-200 bg-zinc-50 ${index === sortedPortraits.length - 1 ? 'border-r' : ''}`}>
										<Image
											src={portrait.data.image}
											alt={portrait.data.title}
											width={560}
											height={747}
											quality="high"
											class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
										/>
									</div>
									<div class="mt-3 h-6 flex items-center px-4">
										<div class="font-medium text-zinc-500">
											{portrait.data.titleComment ? <span data-comment={portrait.data.titleComment}>{portrait.data.title}</span> : portrait.data.title}
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				</section>
				<Comment />
			</main>
		</div>

		<script>
			// Spotlight effect
			const appCards = document.querySelectorAll('.app-card');
			appCards.forEach(card => {
				card.addEventListener('mousemove', (e) => {
					const rect = (card as HTMLElement).getBoundingClientRect();
					const x = (e as MouseEvent).clientX - rect.left;
					const y = (e as MouseEvent).clientY - rect.top;
					(card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
					(card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
				});
			});

			// Page Comment Logic
			document.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				const closeBtn = target.closest('.page-comment-close');
				const backdrop = target.closest('.page-comment-backdrop');
				const trigger = target.closest('[data-comment]') as HTMLElement;

				if (closeBtn || backdrop) return; // Handled by SideComment custom element internally
				
				if (!trigger) return;

				e.preventDefault();
				const sideComment = document.querySelector('side-comment') as any;
				if (sideComment) {
					sideComment.show(trigger, trigger.dataset.comment || '');
				}
			});

			const heroProfilePic = document.getElementById('hero-profile-pic');
			const headerAvatars = document.querySelectorAll('.header-avatar');

			if (heroProfilePic && headerAvatars.length > 0) {
				const observer = new IntersectionObserver(
					([entry]) => {
						headerAvatars.forEach((avatar) => {
							if (!entry.isIntersecting) {
								// Hero pic is out of view, show header avatars
								avatar.classList.remove('opacity-0', '-translate-x-4', 'w-0');
								avatar.classList.add('opacity-100', 'translate-x-0', 'w-5', 'mr-3');
							} else {
								// Hero pic is in view, hide header avatars
								avatar.classList.add('opacity-0', '-translate-x-4', 'w-0');
								avatar.classList.remove('opacity-100', 'translate-x-0', 'w-5', 'mr-3');
							}
						});
					},
					{ threshold: 0 }
				);

				observer.observe(heroProfilePic);
			}
		</script>
	</body>
</html>
