---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&family=Savate:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen flex flex-col items-center text-center">
		<section class="relative w-full min-h-screen flex flex-col items-center justify-center py-20 px-[5vw] overflow-hidden">
			<!-- Heading -->
			<h1 class="font-host font-light text-zinc-700 text-[9vw] md:text-[3vw] leading-[1.05] mb-10 text-center tracking-tight">
				<span class="block whitespace-nowrap">I'm <span class="italic font-savate font-thin text-zinc-900">Sagar</span>,</span>
				<span class="block whitespace-nowrap">a <span id="typing-text" class="italic font-savate font-thin text-zinc-900">Software Engineer</span><span class="cursor inline-block w-[3px] h-[0.8em] bg-[#ff5f1f] ml-1 align-middle mb-1"></span></span>
				<span class="block whitespace-nowrap">based in <span class="italic font-savate font-thin text-zinc-900">Singapore</span>.</span>
			</h1>
		</section>

		<style>
			@keyframes blink {
				0%, 100% { opacity: 1; }
				50% { opacity: 0; }
			}
			.cursor {
				animation: blink 1s infinite;
			}
		</style>

		<script>
			const textElement = document.getElementById('typing-text');
			const phrases = ['Software Engineer', 'Portrait Artist'];
			let phraseIndex = 0;
			let charIndex = phrases[phraseIndex].length;
			let isDeleting = false;
			let typingSpeed = 100;

			function type() {
				const currentPhrase = phrases[phraseIndex];

				if (isDeleting) {
					charIndex--;
					typingSpeed = 50;
				} else {
					charIndex++;
					typingSpeed = 150;
				}

				textElement.textContent = currentPhrase.substring(0, charIndex);

				if (!isDeleting && charIndex === currentPhrase.length) {
					isDeleting = true;
					typingSpeed = 2500;
				} else if (isDeleting && charIndex === 0) {
					isDeleting = false;
					phraseIndex = (phraseIndex + 1) % phrases.length;
					typingSpeed = 500;
				}

				setTimeout(type, typingSpeed);
			}

			// Initial state is full text, so start by waiting then deleting
			isDeleting = true;
			setTimeout(type, 2500);
		</script>

		<main class="w-full mt-[15vw] mb-20 px-[5vw]">
			<section class="w-full">
				<div class="mb-16">
					<h2 class="font-host font-medium text-[4vw] md:text-[1.2vw] uppercase tracking-widest text-primary mb-4">Apps</h2>
					<p class="font-host font-light text-[6vw] md:text-[2.5vw] text-zinc-500">
						These are my personal projects,<br class="md:hidden" /> both past and ongoing:
					</p>
				</div>

				<div class="flex overflow-x-auto no-scrollbar gap-8 snap-x snap-mandatory px-[5vw] -mx-[5vw]">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="flex-none w-[80vw] md:w-[35vw] snap-center group border border-zinc-100 hover:border-primary/30 transition-all duration-500 p-10 bg-zinc-50/50 hover:bg-white hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] text-left"
						>
							<div class="mb-4">
								<img src={app.data.logo} alt={app.data.name} class="w-12 h-12 rounded-lg grayscale group-hover:grayscale-0 transition-all duration-500" />
							</div>
							<h3 class="font-host font-bold text-[5vw] md:text-[2vw] mb-2 text-zinc-900 group-hover:text-primary transition-colors duration-300">{app.data.name}</h3>
							<p class="font-host font-light text-[3.5vw] md:text-[1.2vw] text-zinc-500">
								{app.data.description}
							</p>
						</a>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
