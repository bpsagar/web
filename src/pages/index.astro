---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen">
		<div class="max-w-[500px] mx-auto px-6">
			<Header />
			<section class="relative pt-2 pb-8 overflow-hidden">
				<!-- Heading -->
				<h1 class="font-plus font-semibold tracking-tight text-zinc-400 text-[8vw] md:text-[3vw]">A <span class="text-zinc-900">software engineer</span>, <span class="text-zinc-900">maker</span> and <span class="text-zinc-900">portrait artist</span>, based in Singapore.</h1>
			</section>

			<main class="mt-4 mb-20">
				<section class="w-full">
					<Header title="a maker" />

					<div class="flex flex-col border-t border-zinc-200">
					{sortedApps.map((app) => (
						<div class="group border-b border-x border-zinc-200 transition-colors duration-300 hover:bg-zinc-50/50">
							<input
								type="checkbox"
								id={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
								class="peer hidden"
							/>
							<div class="relative flex items-center gap-4 py-4 px-4 peer-checked:[&_.logo]:scale-200 peer-checked:[&_.desc-grid]:grid-rows-[1fr] peer-checked:[&_.desc-text]:opacity-100">
								<!-- Label for toggle -->
								<label
									for={`app-${app.data.name.toLowerCase().replace(/\s+/g, '-')}`}
									class="absolute inset-0 z-30 cursor-pointer"
								></label>

								<!-- Logo -->
								<div class="flex-shrink-0 z-20 transition-transform duration-500 logo">
									<img
										src={app.data.logo}
										alt={app.data.name}
										class="w-6 h-6 object-contain"
									/>
								</div>

								<!-- Content (Title + Description) -->
								<div class="flex-1 flex flex-col z-20">
									<h3 class="font-host font-bold text-xs text-zinc-900 uppercase tracking-[0.2em] leading-none">
										{app.data.name}
									</h3>
									<div class="grid grid-rows-[0fr] transition-all duration-500 ease-in-out desc-grid">
										<div class="overflow-hidden">
											<p class="font-plus text-[12px] text-zinc-500 leading-relaxed mt-2 opacity-0 transition-opacity duration-500 desc-text">
												{app.data.description}
											</p>
										</div>
									</div>
								</div>

								<!-- Link -->
								<div class="z-40 relative">
									<a
										href={app.data.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-zinc-300 hover:text-zinc-900 transition-colors duration-300 p-1 block"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2.5"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<line x1="7" y1="17" x2="17" y2="7"></line>
											<polyline points="7 7 17 7 17 17"></polyline>
										</svg>
									</a>
								</div>
							</div>
						</div>
					))}
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
