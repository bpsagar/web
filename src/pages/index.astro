---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);

const pillClass = "inline-block px-2.5 py-1 border border-zinc-200 bg-zinc-50/50 rounded-full text-[0.8em] font-instrument leading-none align-middle";
const emojiClass = "inline-block mr-1.5 leading-none";
const labelClass = "inline-block leading-none";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@300..800&family=Instrument+Serif&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen">
		<div class="max-w-[500px] mx-auto px-6">
			<nav class="sticky top-0 z-50 flex items-center h-20 font-host font-medium text-lg bg-transparent">
				<span>sagar.im</span>
			</nav>
			<section class="relative pt-32 pb-16 overflow-hidden">
				<!-- Heading -->
				<h1 class="font-instrument font-thin text-zinc-900 text-[8vw] md:text-[3vw] leading-relaxed tracking-tight">I'm Sagar, a <span class="whitespace-nowrap"><span class={pillClass}><span class={emojiClass}>💻</span><span class={labelClass}>Software Engineer</span></span>,</span> <span class={pillClass}><span class={emojiClass}>🛠️</span><span class={labelClass}>Maker</span></span> and <span class="whitespace-nowrap"><span class={pillClass}><span class={emojiClass}>✍️</span><span class={labelClass}>Portrait Artist</span></span>,</span> based in Singapore.</h1>
			</section>

			<main class="mt-16 mb-20">
				<section class="w-full">
					<div class="mb-12">
						<h2 class="font-host font-bold text-sm uppercase tracking-widest text-primary mb-4">Apps</h2>
						<p class="font-host font-light text-2xl text-zinc-600">
							These are my personal projects,<br class="md:hidden" /> both past and ongoing:
						</p>
					</div>

					<div class="grid grid-cols-1 gap-8">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="group border border-zinc-100 hover:border-primary/30 transition-all duration-500 p-8 bg-zinc-50/50 hover:bg-white hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] text-left"
						>
							<div class="mb-4">
								<img src={app.data.logo} alt={app.data.name} class="w-12 h-12 rounded-lg grayscale group-hover:grayscale-0 transition-all duration-500" />
							</div>
							<h3 class="font-host font-bold text-xl mb-2 text-zinc-900 group-hover:text-primary transition-colors duration-300">{app.data.name}</h3>
							<p class="font-host font-light text-sm text-zinc-500">
								{app.data.description}
							</p>
						</a>
					))}
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
