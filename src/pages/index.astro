---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&family=Savate:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen flex flex-col items-center text-center">
		<section class="relative w-full min-h-screen flex flex-col items-center justify-center py-20 px-[5vw] overflow-hidden">
			<!-- Badge -->
			<div class="absolute top-[10%] right-[5%] md:right-[10%] w-32 h-32 hidden md:block">
				<div class="relative w-full h-full animate-[spin_10s_linear_infinite]">
					<svg viewBox="0 0 100 100" class="w-full h-full overflow-visible">
						<path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none" />
						<text class="font-host text-[9px] uppercase tracking-[0.25em] fill-zinc-300 font-medium">
							<textPath href="#circlePath">Open for projects • Open for projects • </textPath>
						</text>
					</svg>
				</div>
				<div class="absolute inset-0 flex items-center justify-center">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><path d="M7 17l10-10M17 17V7H7" /></svg>
				</div>
			</div>

			<!-- Avatar -->
			<div class="mb-12 relative">
				<div class="w-24 h-24 md:w-32 md:h-32 rounded-full bg-[#ff5f1f]/10 flex items-center justify-center border border-[#ff5f1f]/20 shadow-sm overflow-hidden">
					<img src="https://placehold.co/128x128/ff5f1f/ffffff?text=S" alt="Sagar" class="w-full h-full object-cover" />
				</div>
			</div>

			<!-- Heading -->
			<h1 class="font-savate font-thin text-zinc-900 text-[12vw] md:text-[7.5vw] leading-[1.05] mb-10 text-center tracking-tight">
				<span class="block">I'm <span class="italic">Sagar</span>,</span>
				<span class="block">a <span class="italic">Software Engineer</span></span>
				<span class="block">based in <span class="italic">Singapore</span>.</span>
			</h1>

			<!-- Subtext -->
			<p class="font-host font-light text-[4.5vw] md:text-[1.25vw] text-zinc-400 max-w-xl mx-auto leading-relaxed text-center">
				I'm a software engineer passionate about building clean, performant, and user-centric applications using modern technologies.
			</p>
		</section>

		<main class="w-full mt-[15vw] mb-20 px-[5vw]">
			<section class="w-full">
				<div class="mb-16">
					<h2 class="font-host font-medium text-[4vw] md:text-[1.2vw] uppercase tracking-widest text-primary mb-4">Apps</h2>
					<p class="font-host font-light text-[6vw] md:text-[2.5vw] text-zinc-500">
						These are my personal projects,<br class="md:hidden" /> both past and ongoing:
					</p>
				</div>

				<div class="flex overflow-x-auto no-scrollbar gap-8 snap-x snap-mandatory px-[5vw] -mx-[5vw]">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="flex-none w-[80vw] md:w-[35vw] snap-center group border border-zinc-100 hover:border-primary/30 transition-all duration-500 p-10 bg-zinc-50/50 hover:bg-white hover:shadow-xl hover:shadow-primary/5 rounded-[2rem] text-left"
						>
							<div class="mb-4">
								<img src={app.data.logo} alt={app.data.name} class="w-12 h-12 rounded-lg grayscale group-hover:grayscale-0 transition-all duration-500" />
							</div>
							<h3 class="font-host font-bold text-[5vw] md:text-[2vw] mb-2 text-zinc-900 group-hover:text-primary transition-colors duration-300">{app.data.name}</h3>
							<p class="font-host font-light text-[3.5vw] md:text-[1.2vw] text-zinc-500">
								{app.data.description}
							</p>
						</a>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
