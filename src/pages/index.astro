---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-white text-zinc-900 min-h-screen">
		<div class="max-w-[500px] mx-auto px-6">
			<Header />
			<section class="relative pt-2 pb-8 overflow-hidden">
				<!-- Heading -->
				<h1 class="font-plus font-semibold tracking-tight text-zinc-400 text-[8vw] md:text-[3vw]">A <span class="text-zinc-900">software engineer</span>, <span class="text-zinc-900">maker</span> and <span class="text-zinc-900">portrait artist</span>, based in Singapore.</h1>
			</section>

			<main class="mt-4 mb-20">
				<section class="w-full">
					<Header title="a maker" />

					<div class="grid grid-cols-1 gap-3">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="group flex items-start gap-4 border border-zinc-200 transition-all duration-300 p-4 bg-zinc-50/50 hover:bg-zinc-100 hover:border-zinc-300 rounded-2xl text-left"
						>
							<div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-zinc-50 border border-zinc-100 rounded-xl overflow-hidden mt-0.5">
								<img src={app.data.logo} alt={app.data.name} class="w-7 h-7 grayscale group-hover:grayscale-0 transition-all duration-500" />
							</div>
							<div class="flex-1 min-w-0 py-0.5">
								<div class="flex items-center justify-between mb-1">
									<h3 class="font-host font-bold text-base text-zinc-900 group-hover:text-primary transition-colors duration-300 leading-tight">
										{app.data.name}
									</h3>
									<span class="text-zinc-400 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
									</span>
								</div>
								<p class="font-host font-light text-sm text-zinc-500 leading-relaxed">
									{app.data.description}
								</p>
							</div>
						</a>
					))}
					</div>
				</section>
			</main>
		</div>
	</body>
</html>
