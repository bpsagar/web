---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allApps = await getCollection('apps');
const sortedApps = allApps.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&family=Savate:ital,wght@1,200..900&display=swap" rel="stylesheet">
		<title>Sagar Chakravarthy</title>
	</head>
	<body class="bg-black text-white min-h-screen p-[5vw] md:p-[8vw] flex flex-col gap-[15vw]">
		<header class="w-full">
			<h1 class="font-savate italic font-extralight text-white text-[10vw] leading-[0.85] mb-[6vw]">
				Sagar Chakravarthy
			</h1>
			<p class="font-host font-light text-[5vw] leading-[1.1] max-w-[15ch] md:max-w-[12ch]">
				Building apps and sketching faces.
			</p>
		</header>

		<main class="w-full">
			<section>
				<h2 class="font-host font-normal text-[3vw] md:text-[1.5vw] uppercase tracking-widest text-gray-500 mb-2">Apps</h2>
				<p class="font-host font-light text-[4vw] md:text-[2vw] text-gray-300 mb-8">
					These are my personal projects, both past and ongoing:
				</p>

				<div class="flex overflow-x-auto no-scrollbar gap-6 snap-x snap-mandatory -mx-[5vw] px-[5vw] md:-mx-[8vw] md:px-[8vw]">
					{sortedApps.map((app) => (
						<a
							href={app.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="flex-none w-[66vw] md:w-[25.7vw] snap-start group border border-transparent hover:border-primary transition-colors duration-300 p-6 bg-zinc-900/50 rounded-xl"
						>
							<div class="mb-4">
								<img src={app.data.logo} alt={app.data.name} class="w-12 h-12 rounded-lg" />
							</div>
							<h3 class="font-host font-bold text-[5vw] md:text-[2vw] mb-2">{app.data.name}</h3>
							<p class="font-host font-light text-[3.5vw] md:text-[1.2vw] text-gray-400">
								{app.data.description}
							</p>
						</a>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
